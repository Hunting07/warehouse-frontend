<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.teach.javafx.controller.base.ProfileController"
      alignment="CENTER" spacing="20">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="个人中心" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <TitledPane text="个人信息" expanded="true">
        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" minWidth="80"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
            </columnConstraints>

            <Label text="用户名：" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Label fx:id="usernameLabel" text="" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="角色：" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <Label fx:id="roleLabel" text="" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="姓名：" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="nameField" promptText="请输入姓名" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="电话：" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="phoneField" promptText="请输入电话" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Button text="保存信息" onAction="#handleUpdateProfile" GridPane.rowIndex="4" GridPane.columnIndex="1"
                    style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        </GridPane>
    </TitledPane>

    <TitledPane text="修改密码" expanded="false">
        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" minWidth="100"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
            </columnConstraints>

            <Label text="旧密码：" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <PasswordField fx:id="oldPasswordField" promptText="请输入旧密码" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="新密码：" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <PasswordField fx:id="newPasswordField" promptText="请输入新密码" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="确认新密码：" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <PasswordField fx:id="confirmPasswordField" promptText="请再次输入新密码" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Button text="修改密码" onAction="#handleChangePassword" GridPane.rowIndex="3" GridPane.columnIndex="1"
                    style="-fx-background-color: #FF9800; -fx-text-fill: white;"/>
        </GridPane>
    </TitledPane>

    <Button text="退出登录" onAction="#handleLogout"
            style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-size: 14px; -fx-pref-width: 150;"/>

</VBox>
