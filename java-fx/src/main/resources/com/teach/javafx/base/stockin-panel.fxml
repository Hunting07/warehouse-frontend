<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teach.javafx.controller.base.StockInController">

    <!-- 顶部工具栏 -->
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- 搜索和筛选区域 -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="入库单号："/>
                <TextField fx:id="searchCodeField" prefWidth="150"/>

                <Label text="入库类型："/>
                <ComboBox fx:id="typeComboBox" prefWidth="120"/>

                <Label text="状态："/>
                <ComboBox fx:id="statusComboBox" prefWidth="100"/>

                <Button text="查询" onAction="#onSearchButtonClick"/>
                <Button text="重置" onAction="#onResetButtonClick"/>
            </HBox>

            <!-- 操作按钮区域 -->
            <HBox spacing="10">
                <Button text="新增入库单" onAction="#onAddButtonClick"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                <Button text="编辑" onAction="#onEditButtonClick"/>
                <Button text="删除" onAction="#onDeleteButtonClick"
                        style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                <Button text="审批" onAction="#onApproveButtonClick"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
                <Button text="确认入库" onAction="#onCompleteButtonClick"
                        style="-fx-background-color: #FF9800; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </top>

    <!-- 中间数据表格 -->
    <center>
        <TableView fx:id="stockInTable" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="idColumn" text="编号" prefWidth="60"/>
                <TableColumn fx:id="inCodeColumn" text="入库单号" prefWidth="150"/>
                <TableColumn fx:id="typeColumn" text="入库类型" prefWidth="120"/>
                <TableColumn fx:id="totalAmountColumn" text="总金额" prefWidth="100"/>
                <TableColumn fx:id="statusColumn" text="状态" prefWidth="80"/>
                <TableColumn fx:id="createTimeColumn" text="申请时间" prefWidth="150"/>
                <TableColumn fx:id="approveTimeColumn" text="审批时间" prefWidth="150"/>
            </columns>
        </TableView>
    </center>
</BorderPane>

