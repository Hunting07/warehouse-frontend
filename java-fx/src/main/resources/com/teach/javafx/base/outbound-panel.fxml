<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.teach.javafx.controller.base.OutboundApplyController">

    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
            </padding>
            <HBox spacing="10">
                <Label text="申请人姓名："/>
                <TextField fx:id="applicantNameField" promptText="申请人姓名" prefWidth="150"/>
                <Label text="出库类型："/>
                <ComboBox fx:id="outTypeComboBox" prefWidth="150"/>
            </HBox>
            <HBox spacing="10">
                <Label text="备注："/>
                <TextField fx:id="remarkField" promptText="填写出库备注" prefWidth="600"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="detailTableView" editable="true">
            <columns>
                <TableColumn fx:id="materialCol" text="物资名称" prefWidth="200"/>
                <TableColumn fx:id="goodsSpecCol" text="规格型号" prefWidth="120"/>
                <TableColumn fx:id="unitCol" text="单位" prefWidth="80"/>
                <TableColumn fx:id="outNumCol" text="出库数量" prefWidth="100"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="15">
            <padding>
                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0" />
            </padding>
            <Button text="添加商品" onAction="#onAdd" prefWidth="100"/>
            <Button text="删除选中" onAction="#onDelete" prefWidth="100"/>
            <Button text="提交出库" onAction="#onSubmit" prefWidth="100"/>
        </HBox>
    </bottom>

</BorderPane>
