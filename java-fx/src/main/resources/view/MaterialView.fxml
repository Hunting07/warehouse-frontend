<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teach.javafx.controller.base.MaterialController"
            prefHeight="400.0" prefWidth="600.0">
    <top>
        <HBox spacing="10" padding="10">
            <Button text="新增物资" onAction="#addMaterial"/>
            <Button text="编辑物资" onAction="#editMaterial"/>
            <Button text="删除物资" onAction="#deleteMaterial"/>
        </HBox>
    </top>
    <center>
        <TableView fx:id="materialTable">
            <columns>
                <TableColumn fx:id="idCol" text="物资编号"/>
                <TableColumn fx:id="nameCol" text="物资名称"/>
                <TableColumn fx:id="categoryNameCol" text="所属分类"/>
                <TableColumn fx:id="currentStockCol" text="当前库存"/>
                <TableColumn fx:id="safetyStockCol" text="安全库存"/>
                <TableColumn fx:id="createTimeCol" text="创建时间"/>
                <TableColumn fx:id="actionCol" text="操作"/>
            </columns>
        </TableView>
    </center>
</BorderPane>

