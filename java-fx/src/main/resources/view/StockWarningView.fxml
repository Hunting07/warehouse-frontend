<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.teach.javafx.controller.base.StockWarningController"
            prefHeight="600.0" prefWidth="1200.0">
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <Label text="⚠️ 库存预警 - 需要及时补货" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #d32f2f;"/>

            <HBox spacing="20" alignment="CENTER_LEFT">
                <VBox spacing="5" style="-fx-background-color: #ffcdd2; -fx-padding: 15 30 15 30; -fx-background-radius: 8;">
                    <Label text="库存不足" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                    <Label fx:id="warningCountLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #d32f2f;"/>
                </VBox>

                <VBox spacing="5" style="-fx-background-color: #f5f5f5; -fx-padding: 15 30 15 30; -fx-background-radius: 8;">
                    <Label text="总计" style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
                    <Label fx:id="totalCountLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #424242;"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="搜索:"/>
                <TextField fx:id="searchField" promptText="输入物资名称或编码搜索..." prefWidth="250"/>
                <Button text="搜索" onAction="#searchWarning" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 4;"/>
                <Button text="重置" onAction="#resetSearch" style="-fx-cursor: hand; -fx-background-radius: 4;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="exportBtn" text=" 导出" onAction="#exportWarnings" style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 4;"/>
                <Button text=" 刷新" onAction="#loadWarnings" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 4;"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="warningTable" prefHeight="500.0">
            <columns>
                <TableColumn fx:id="idCol" text="序号" prefWidth="60"/>
                <TableColumn fx:id="nameCol" text="物资名称" prefWidth="180"/>
                <TableColumn fx:id="codeCol" text="物资编码" prefWidth="150"/>
                <TableColumn fx:id="categoryNameCol" text="所属分类" prefWidth="150"/>
                <TableColumn fx:id="currentStockCol" text="当前库存" prefWidth="100"/>
                <TableColumn fx:id="safetyStockCol" text="安全库存" prefWidth="100"/>
                <TableColumn fx:id="shortageCol" text="短缺数量" prefWidth="100"/>
                <TableColumn fx:id="updateTimeCol" text="更新时间" prefWidth="180"/>
                <TableColumn fx:id="actionCol" text="操作" prefWidth="100"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
