<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.teach.javafx.controller.base.StockWarningController"
            prefHeight="600.0" prefWidth="1200.0">
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <Label text="⚠️ 库存预警列表" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <GridPane hgap="15" vgap="5">
                <padding>
                    <Insets top="5" right="5" bottom="5" left="5"/>
                </padding>
                <columnConstraints>
                    <javafx.scene.layout.ColumnConstraints halignment="CENTER"/>
                    <javafx.scene.layout.ColumnConstraints halignment="CENTER"/>
                    <javafx.scene.layout.ColumnConstraints halignment="CENTER"/>
                    <javafx.scene.layout.ColumnConstraints halignment="CENTER"/>
                </columnConstraints>

                <VBox spacing="5" GridPane.columnIndex="0" style="-fx-background-color: #ffcccc; -fx-padding: 10; -fx-background-radius: 5;">
                    <Label text="严重预警" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    <Label fx:id="severeCountLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #d32f2f;"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" style="-fx-background-color: #fff4cc; -fx-padding: 10; -fx-background-radius: 5;">
                    <Label text="警告" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    <Label fx:id="warningCountLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f57c00;"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="2" style="-fx-background-color: #e3f2fd; -fx-padding: 10; -fx-background-radius: 5;">
                    <Label text="提示" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    <Label fx:id="noticeCountLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1976d2;"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="3" style="-fx-background-color: #f5f5f5; -fx-padding: 10; -fx-background-radius: 5;">
                    <Label text="总计" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                    <Label fx:id="totalCountLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #424242;"/>
                </VBox>
            </GridPane>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="物资名称:"/>
                <TextField fx:id="searchField" promptText="输入物资名称或编码搜索..." prefWidth="200"/>
                <Label text="预警级别:"/>
                <ComboBox fx:id="warningLevelFilter" prefWidth="120"/>
                <Button text="搜索" onAction="#searchWarning" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Button text="重置" onAction="#resetSearch" style="-fx-cursor: hand;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="📊 导出" onAction="#exportWarnings" style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Button text="🔄 刷新" onAction="#loadWarnings" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="warningTable" prefHeight="500.0">
            <columns>
                <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                <TableColumn fx:id="nameCol" text="物资名称" prefWidth="150"/>
                <TableColumn fx:id="codeCol" text="物资编码" prefWidth="120"/>
                <TableColumn fx:id="categoryNameCol" text="所属分类" prefWidth="120"/>
                <TableColumn fx:id="currentStockCol" text="当前库存" prefWidth="80"/>
                <TableColumn fx:id="safetyStockCol" text="安全库存" prefWidth="80"/>
                <TableColumn fx:id="shortageCol" text="短缺数量" prefWidth="80"/>
                <TableColumn fx:id="warningThresholdCol" text="预警阈值" prefWidth="80"/>
                <TableColumn fx:id="warningLevelCol" text="预警级别" prefWidth="100"/>
                <TableColumn fx:id="updateTimeCol" text="更新时间" prefWidth="160"/>
                <TableColumn fx:id="actionCol" text="操作" prefWidth="100"/>
            </columns>
        </TableView>
    </center>
</BorderPane>