<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="1000" prefHeight="700" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.teach.javafx.controller.base.OutboundApplyController">
    <!-- 顶部操作栏 -->
    <top>
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #f5f7fa;">
            <Label text="出库申请" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="申请备注：" style="-fx-font-size: 14px;"/>
                <TextField fx:id="remarkField" prefWidth="500" promptText="请输入本次出库的备注信息"/>
            </HBox>
            <HBox spacing="15">
                <Button text="添加商品" onAction="#addGoods" style="-fx-background-color: #409eff; -fx-text-fill: white; -fx-pref-width: 100; -fx-pref-height: 35;"/>
                <Button text="删除选中" onAction="#deleteGoods" style="-fx-background-color: #f56c6c; -fx-text-fill: white; -fx-pref-width: 100; -fx-pref-height: 35;"/>
                <Button text="提交申请" onAction="#submitApply" style="-fx-background-color: #67c23a; -fx-text-fill: white; -fx-pref-width: 100; -fx-pref-height: 35;"/>
            </HBox>
        </VBox>
    </top>

    <!-- 中间商品明细表格 -->
    <center>
        <TableView fx:id="detailTableView" style="-fx-padding: 10;">
            <columns>
                <TableColumn fx:id="goodsNameCol" text="商品名称" prefWidth="200" editable="true"/>
                <TableColumn fx:id="goodsSpecCol" text="规格" prefWidth="120" editable="true"/>
                <TableColumn fx:id="unitCol" text="单位" prefWidth="80" editable="true"/>
                <TableColumn fx:id="outNumCol" text="出库数量" prefWidth="100" editable="true"/>
                <TableColumn fx:id="unitPriceCol" text="单价(元)" prefWidth="120" editable="true"/>
                <TableColumn fx:id="totalPriceCol" text="小计(元)" prefWidth="120"/>
            </columns>
        </TableView>
    </center>
</BorderPane>