<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- 绑定对应的控制器类 -->
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teach.javafx.controller.base.UserApproveController"
            prefWidth="1000" prefHeight="700">

    <!-- 顶部标题 + 搜索栏 -->
    <top>
        <VBox spacing="15" padding="20" style="-fx-background-color:#f5f7fa;">
            <Label text="用户申请审批" style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#2c3e50;"/>

            <!-- 搜索筛选栏 -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="搜索申请单号/申请人姓名" prefWidth="300"/>
                <Button text="查询" onAction="#handleSearch" style="-fx-background-color:#165DFF;-fx-text-fill:white;-fx-pref-width:80;"/>
                <Button text="刷新列表" onAction="#loadApplyList" style="-fx-background-color:#28a745;-fx-text-fill:white;-fx-pref-width:80;"/>
            </HBox>
        </VBox>
    </top>

    <!-- 中间审批列表表格 -->
    <center>
        <VBox padding="20">
            <TableView fx:id="applyTable" prefHeight="500">
                <columns>
                    <TableColumn fx:id="colApplyNo" text="申请单号" prefWidth="180" style="-fx-font-size:14px;"/>
                    <TableColumn fx:id="colName" text="申请人" prefWidth="120" style="-fx-font-size:14px;"/>
                    <TableColumn fx:id="colRole" text="申请角色" prefWidth="150" style="-fx-font-size:14px;"/>
                    <TableColumn fx:id="colTime" text="申请时间" prefWidth="180" style="-fx-font-size:14px;"/>
                    <TableColumn fx:id="colStatus" text="审批状态" prefWidth="120" style="-fx-font-size:14px;"/>
                    <TableColumn fx:id="colOperate" text="操作" prefWidth="200" style="-fx-font-size:14px;"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
